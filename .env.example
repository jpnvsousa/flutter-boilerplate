# ============================================================
# Flutter Boilerplate — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file with real credentials.
#
# Usage:
#   flutter run --dart-define-from-file=.env.local
#
# Production:
#   flutter build appbundle --dart-define-from-file=.env.production
# ============================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Found at: https://app.revenuecat.com/apps
RC_APPLE_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RC_GOOGLE_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sentry ────────────────────────────────────────────────────────────────────
# Found at: https://sentry.io/<org>/<project>/settings/
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o0.ingest.sentry.io/0

# ── App ───────────────────────────────────────────────────────────────────────
# "development" | "staging" | "production"
ENVIRONMENT=development
